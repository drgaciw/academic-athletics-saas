{
  "name": "@aah/service-ai",
  "version": "2.0.0",
  "private": true,
  "description": "AI microservice for conversational interfaces, RAG pipelines, and agentic workflows",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --external @ai-sdk/openai --external @ai-sdk/anthropic",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aah/ai": "workspace:*",
    "@aah/api-utils": "workspace:*",
    "@aah/auth": "workspace:*",
    "@aah/config": "workspace:*",
    "@aah/database": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.65",
    "@ai-sdk/openai": "^3.0.65",
    "@hono/zod-validator": "^0.8.0",
    "ai": "^6.0.191",
    "compromise": "^14.14.0",
    "crypto-js": "^4.2.0",
    "hono": "^4.7.11",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.8.6",
    "jest": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "ts-jest": "^29.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  },
  "keywords": ["ai", "llm", "rag", "agents", "conversational-ai"],
  "engines": {
    "node": ">=20.19.0"
  }
}
