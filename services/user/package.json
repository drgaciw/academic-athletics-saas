{
  "name": "@aah/service-user",
  "version": "2.0.0",
  "private": true,
  "description": "User management microservice for Athletic Academics Hub",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aah/api-utils": "workspace:*",
    "@aah/auth": "workspace:*",
    "@aah/config": "workspace:*",
    "@aah/database": "workspace:*",
    "@clerk/backend": "^3.4.13",
    "hono": "^4.7.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.8.6",
    "jest": "^30.4.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
