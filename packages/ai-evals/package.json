{
  "name": "@aah/ai-evals",
  "version": "1.0.0",
  "description": "AI evaluation framework for Athletic Academics Hub",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./scorers": "./src/scorers.ts"
  },
  "scripts": {
    "dev": "echo 'AI Evals CLI - Use: npm run eval, npm run compare, or npm run report'",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "cli": "tsx cli.ts",
    "eval": "tsx cli.ts eval",
    "compare": "tsx cli.ts compare",
    "report": "tsx cli.ts report"
  },
  "dependencies": {
    "@aah/ai": "workspace:*",
    "@aah/database": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.65",
    "@ai-sdk/openai": "^3.0.65",
    "@vercel/analytics": "^1.3.1",
    "ai": "^6.0.191",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "figlet": "^1.9.4",
    "inquirer": "^13.1.0",
    "ora": "^8.1.0",
    "table": "^6.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.8.6",
    "jest": "^30.4.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "evaluation",
    "testing",
    "llm",
    "quality-assurance"
  ]
}
