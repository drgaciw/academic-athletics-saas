{
  "extends": "../config/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "cli.ts",
    "src/index.ts",
    "src/base-runner.ts",
    "src/dataset-manager.ts",
    "src/model-comparison.ts",
    "src/scorers.ts",
    "src/metrics.ts",
    "src/types.ts",
    "src/cli/**/*.ts",
    "src/config/**/*.ts",
    "src/db/**/*.ts",
    "src/errors/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/runners/**/*",
    "src/datasets/**/*",
    "src/orchestrator/**/*",
    "src/monitoring/**/*",
    "src/performance/**/*",
    "src/safety/**/*",
    "src/types/**/*",
    "src/__tests__/**/*"
  ]
}
